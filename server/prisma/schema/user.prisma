model User {
  id        String   @id @default(uuid())
  companyId String
  name      String
  email     String   @unique
  password  String
  role      Role     @default(AGENT)
  createdAt DateTime @default(now())

  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  leads       Lead[]           @relation("AssignedLeads")
  tasks       Task[]           @relation("AssignedTasks")
  activities  ActivityLog[]
  permissions UserPermission[]

  @@index([companyId])
}

// Action-level access per module (user level).
// One row per user per module. ADMIN bypasses these checks in code.
// The company grants/edits these when adding or editing an employee.
model UserPermission {
  id        String           @id @default(uuid())
  userId    String
  module    PermissionModule
  canView   Boolean          @default(false)
  canCreate Boolean          @default(false)
  canEdit   Boolean          @default(false)
  canDelete Boolean          @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, module])
  @@index([userId])
}
